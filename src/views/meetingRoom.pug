doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(http-equiv="X-UA-Compatible", content="IE=edge")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        link(rel="stylesheet", href="https://use.fontawesome.com/releases/v5.15.4/css/all.css", integrity="sha384-DyZ88mC6Up2uqS4h/KRgHuoeGwBcD4Ng9SiP4dIRy0EXTlnuz47vAwmeGwVChigm", crossorigin="anonymous")
        //- link(rel="stylesheet", href="https://unpkg.com/mvp.css")
        link(href="https://fonts.googleapis.com/css2?family=Nanum+Myeongjo:wght@700&display=swap" rel="stylesheet")
        link(rel="stylesheet", href="./public/css/style.css")
        title Meeting
    body 
        header
            //- i(class="fab fa-pied-piper-square fa-2x")
            h1#logo TEAM JLB
        main
            div#welcome 
                form
                    h3#welcometitle ✅ 회의 참여하기
                    input#roomName(type="text", required, placeholder="회의실 이름을 입력하세요.")
                    input#nickname(type="text", required, placeholder="회의실에서 사용할 이름을 입력하세요.")
                    button 입장하기

            div#call(class="call")
                div#streamBox
                    div#streams
                        div#myStream(class="people1")
                            video#myFace(autoplay, playsinline)
                            h3#userNickname  
                    div#controlers
                        div#controlers_column1
                            select#cameras
                        div#controlers_column2
                            div#buttons
                                button#mute
                                    i(class="fas fa-microphone fa-2x unMuteIcon")
                                    i(class="fas fa-microphone-slash fa-2x muteIcon")
                                button#camera 
                                    i(class="fas fa-video fa-2x cameraIcon")
                                    i(class="fas fa-video-slash fa-2x unCameraIcon")
                                button#chatapp
                                    i(class="fas fa-comment fa-2x chatIcon")
                                button#memoapp
                                    i(class="fa fa-sticky-note fa-2x memoIcon")
                        div#controlers_column3
                            button#leave 회의 나가기
                div#chatRoom
                    div#chatview
                        div
                            h3 CHAT
                        ul#chatBox
                        form#chatForm
                            input(required, type="text" placeholder="메세지를 입력하세요...")
                            button 전송
                    div#memo(hidden)
                        div#memotitle
                            h3 MEMO
                        div#memoarea
                            textarea#memotext(placeholder="메모를 작성하세요...")

        aside.modal.hidden
            div.modal__box
                h2.modal__text
                button.modal__btn OK

        script(src="/socket.io/socket.io.js")
        script(src="/public/js/meetingRoom.js")